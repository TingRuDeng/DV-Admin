# Compose 本地模板配置；生产环境必须使用独立 secret 与外部配置。
APP_ENV=development
APP_NAME=DV-Admin FastAPI
DEBUG=true
DATABASE_URL=mysql://dv_admin:dv_admin_password@mysql:3306/dv_admin
DATABASE_MIN_CONNECTIONS=1
DATABASE_MAX_CONNECTIONS=10
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
SECRET_KEY=compose-dev-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=6
PASSWORD_MAX_LENGTH=20
DEFAULT_PASSWORD=ChangeMe!2026
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
LOG_LEVEL=INFO
LOG_FORMAT=json
ALLOWED_ORIGINS=http://localhost:9527,http://127.0.0.1:9527
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
CACHE_TTL=300
