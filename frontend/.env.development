# 应用端口
VITE_APP_PORT=9527
# 应用名称及Title（同时用于页面标题和Logo旁的平台名称）
VITE_APP_TITLE=DV-Admin
# 应用Logo文字（展开时显示，折叠时自动取首字母）
VITE_APP_LOGO_TEXT=DV
# 代理前缀
VITE_APP_BASE_API=/dev-api

# 接口地址
VITE_APP_API_URL=http://127.0.0.1:8769

# 开发环境静态资源接口
VITE_APP_STATIC_URL=http://127.0.0.1:8769/

# WebSocket 端点（不配置则关闭），本地 ws://127.0.0.1:8989/ws
VITE_APP_WS_ENDPOINT=

# 启用 Mock 服务
VITE_MOCK_DEV_SERVER=false

# 是否启用验证码功能
VITE_ENABLE_CAPTCHA=false

# API 版本前缀 (例如: v1, v2)，留空则不使用版本号
VITE_APP_API_VERSION=v1
