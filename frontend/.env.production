# 代理前缀
VITE_APP_BASE_API='/prod-api'
# 项目名称
VITE_APP_TITLE=DV-Admin
# 应用Logo文字（折叠时显示）
VITE_APP_LOGO_TEXT=D
# 应用Logo文字（展开时显示）
VITE_APP_LOGO_TEXT_FULL=DV
# 平台名称（显示在Logo旁边）
VITE_APP_PLATFORM_NAME=DV Admin
# WebSocket端点(可选)
#VITE_APP_WS_ENDPOINT=

# 是否启用验证码功能
VITE_ENABLE_CAPTCHA=false

# API 版本前缀 (例如: v1, v2)，留空则不使用版本号
VITE_APP_API_VERSION=v1
